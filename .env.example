# =============================================================================
#  Zivame Clone — Environment Variables
#  Copy this file to .env and fill in your values.
#
#  ZERO-SPEND DEFAULTS:
#    - All paid service keys are left blank.
#    - Blank keys → free fallbacks automatically activate.
#    - See README.md for what each fallback does.
# =============================================================================


# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Zivame Clone API
APP_ENV=development
APP_DEBUG=true


# ── Database (self-hosted via Docker — FREE) ──────────────────────────────────
POSTGRES_USER=zivame
POSTGRES_PASSWORD=zivame_secret
POSTGRES_DB=zivame_db
DATABASE_URL=postgresql+asyncpg://zivame:zivame_secret@postgres:5432/zivame_db


# ── Redis (self-hosted via Docker — FREE) ────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@redis:6379/0


# ── JWT (generate your own secret: python -c "import secrets; print(secrets.token_hex(64))") ──
JWT_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_BEFORE_DEPLOYING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


# ── OTP Settings ──────────────────────────────────────────────────────────────
OTP_EXPIRE_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_LENGTH=6


# ── Image Storage (LOCAL — FREE) ──────────────────────────────────────────────
# Images saved to /app/static/uploads inside the Docker container.
# Served at http://localhost:8000/static/uploads/...
LOCAL_STORAGE_PATH=/app/static/uploads
LOCAL_STORAGE_URL=http://localhost:8000/static/uploads

# ── Image Storage (AWS S3 — PAID, uncomment when ready) ──────────────────────
# When both keys are set, S3 is used instead of local storage.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=zivame-products
# AWS_S3_REGION=ap-south-1


# ── SMS OTP (CONSOLE LOG — FREE) ─────────────────────────────────────────────
# When TWILIO_ACCOUNT_SID is blank, OTP is printed to server logs.
# Check logs with: docker compose logs -f backend
# You will see a box like:
#   ====================================================
#   [OTP — SMS]  LOGIN
#   To      : +919876543210
#   OTP     : 482910
#   ====================================================

# ── SMS OTP (Twilio — PAID, uncomment when ready) ────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=


# ── Email OTP (CONSOLE LOG — FREE) ───────────────────────────────────────────
# Default: OTP is printed to server logs (same box format as SMS above).
#
# FREE SMTP option (uncomment and fill in to send real emails for free):
# Works with Gmail App Password, Mailtrap free tier, etc.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-gmail@gmail.com
# SMTP_PASSWORD=your-gmail-app-password     # Google → Security → App Passwords
# SMTP_USE_TLS=true
#
# Email sender name shown to users:
SENDGRID_FROM_EMAIL=noreply@zivame-clone.com
SENDGRID_FROM_NAME=Zivame Clone

# ── Email OTP (SendGrid — PAID optional, 100/day free tier, uncomment when ready) ──
# SENDGRID_API_KEY=


# ── AI Assistant (RULE-BASED — FREE) ─────────────────────────────────────────
# When both keys are blank, the assistant uses keyword-based responses.
# It handles: sizing, returns, delivery, payments, care instructions, etc.
# Good enough for development and low-traffic production.

# ── AI Assistant (Claude — PAID, uncomment when ready) ───────────────────────
# ANTHROPIC_API_KEY=

# ── AI Assistant (OpenAI fallback — PAID, uncomment when ready) ──────────────
# OPENAI_API_KEY=


# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Zivame Clone


# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Razorpay (optional — free account at razorpay.com) ────────────────────────
# COD and UPI work without this. Only needed for card/net banking payments.
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
